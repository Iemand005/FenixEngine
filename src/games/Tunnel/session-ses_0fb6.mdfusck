Let me design the new GrowPath:

```cpp
void GrowPath(int count) {
    float t = window->GetTime();
    int freeSeg = (path.size() - 4) / 3;
    for (int i = 0; i < count; i++) {
        int n = path.size();
        float seg = freeSeg;
        float ampMod = 0.2 + 0.8 * pow(abs(sin(seg * 0.12 + t * 0.02)), 2.0);
        if (n % 3 == 1) {
            path.push_back(2.0f * path[n-1] - path[n-2]);
        } else if (n % 3 == 2) {
            glm::vec3 dir = path[n-1] - path[n-2];
            float dirLen = glm::length(dir);
            glm::vec3 step = (dirLen > 1e-6f)
                ? dir * (60.0f / dirLen)
                : glm::vec3(0, 0, 60);
            
            float turnAmp = 4.0f * turnStrength * ampMod;
            float twistAmp = 2.5f * twistStrength * ampMod;
            
            glm::vec3 wobble(
                sin(t * 0.7f + seg * 0.7f) * turnAmp,
                cos(t * 0.5f + seg * 0.5f) * twistAmp,
                sin(t * 0.3f + seg * 1.1f) * 3.0f * ampMod);
            
            // Swirl
            float swirlAmp = 5.0f * swirlStrength * ampMod;
            float sa = seg * 0.3f + t * 0.08f;
            wobble.x += sin(sa) * swirlAmp;
            wobble.z += cos(sa) * swirlAmp;
            
            path.push_back(path[n-1] + step + wobble);
        } else {
            // Similar for P3...
        }
    }
}
```

