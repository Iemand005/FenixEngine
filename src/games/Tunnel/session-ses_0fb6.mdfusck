315: 
316: 			float audioR = 0.0f, audioG = 0.0f, audioB = 0.0f;
317: 			for (int i = 0; i < NUM_BARS; i++) {
318: 				float val = visualizer.bandMagnitudesSmoothed[i];
319: 				float frac = (float)i / NUM_BARS;
320: 				audioR += val * (1.0f - frac);
321: 				audioG += val * (0.5f - fabs(frac - 0.5f) * 2.0f);
322: 				audioB += val * frac;
323: 			}
324: 			float total = audioR + audioG + audioB;
325: 			if (total > 0.0f) {
326: 				audioR /= total; audioG /= total; audioB /= total;
327: 			}
328: 			scene->GetLights()[0].position = cameraPos;
329: 			scene->GetLights()[0].color = glm::vec3(1.0f, 0.9f, 0.7f) + glm::vec3(audioR, audioG, audioB) * 0.4f;
330: 			scene->GetLights()[0].intensity = 3.0f;
331: 			scene->GetLights()[0].radius = 80.0f;
332: 
333: 			shader->Use();
334: 			shader->SetFloat("wobbleAmount", motionAmount);
335: 			shader->SetFloat("roundness", tunnelRoundness);
336: 			shader->SetFloat("haustraStrength", haustraStrength);
337: 			shader->SetFloat("animSpeed", animationSpeed);
338: 			shader->SetFloat("time", elapsedTime);
339: 			shader->SetVec3("objectColor", glm::vec3(0.55f, 0.08f, 0.12f));
