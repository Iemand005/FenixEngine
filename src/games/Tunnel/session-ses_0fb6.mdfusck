105: 	void GrowPath(int count) {
106: 		float t = window->GetTime();
107: 		int freeSeg = (path.size() - 4) / 3;
108: 		for (int i = 0; i < count; i++) {
109: 			int n = path.size();
110: 			if (n % 3 == 1) {
111: 				path.push_back(2.0f * path[n-1] - path[n-2]);
112: 			} else if (n % 3 == 2) {
113: 				glm::vec3 dir = path[n-1] - path[n-2];
114: 				float dirLen = glm::length(dir);
115: 				glm::vec3 step = (dirLen > 1e-6f)
116: 					? dir * (60.0f / dirLen)
117: 					: glm::vec3(0, 0, 60);
118: 				glm::vec3 wobble(
119: 					sin(t * 0.7f + freeSeg * 0.7f) * 3.0f,
120: 					cos(t * 0.5f + freeSeg * 0.5f) * 1.5f,
121: 					0.0f);
122: 				path.push_back(path[n-1] + step + wobble);
123: 			} else {
124: 				glm::vec3 dir = path[n-1] - path[n-2];
125: 				float dirLen = glm::length(dir);
126: 				glm::vec3 step = (dirLen > 1e-6f)
127: 					? dir * (60.0f / dirLen)
128: 					: glm::vec3(0, 0, 60);
129: 				glm::vec3 wobble(
130: 					sin(t * 0.5f + freeSeg * 0.5f) * 4.0f,
131: 					cos(t * 0.3f + freeSeg * 0.3f) * 2.0f,
132: 					0.0f);
133: 				path.push_back(path[n-1] + step + wobble);
134: 				freeSeg++;
135: 			}
136: 		}
137: 	}
