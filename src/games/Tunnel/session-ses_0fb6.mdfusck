115: 	void GrowPath(int count) {
116: 		float t = window->GetTime();
117: 		int freeSeg = (path.size() - 4) / 3;
118: 		for (int i = 0; i < count; i++) {
119: 			int n = path.size();
120: 			float seg = freeSeg;
121: 			float ampMod = 0.2 + 0.8 * pow(abs(sin(seg * 0.12 + t * 0.02)), 2.0);
122: 			if (n % 3 == 1) {
123: 				path.push_back(2.0f * path[n-1] - path[n-2]);
124: 			} else if (n % 3 == 2) {
125: 				glm::vec3 dir = path[n-1] - path[n-2];
126: 				float dirLen = glm::length(dir);
127: 				glm::vec3 step = (dirLen > 1e-6f)
128: 					? dir * (60.0f / dirLen)
129: 					: glm::vec3(0, 0, 60);
130: 				float sa = seg * 0.3f + t * 0.08f;
131: 				glm::vec3 wobble(
132: 					(sin(t * 0.7f + seg * 0.7f) * 4.0f * turnStrength
133: 					 + sin(sa) * 5.0f * swirlStrength) * ampMod,
134: 					(cos(t * 0.5f + seg * 0.5f) * 2.5f * twistStrength) * ampMod,
135: 					(sin(t * 0.3f + seg * 1.1f) * 3.0f
136: 					 + cos(sa) * 5.0f * swirlStrength) * ampMod);
137: 				path.push_back(path[n-1] + step + wobble);
138: 			} else {
139: 				glm::vec3 dir = path[n-1] - path[n-2];
140: 				float dirLen = glm::length(dir);
141: 				glm::vec3 step = (dirLen > 1e-6f)
142: 					? dir * (60.0f / dirLen)
143: 					: glm::vec3(0, 0, 60);
144: 				float sa = seg * 0.3f + t * 0.08f;
145: 				glm::vec3 wobble(
146: 					(sin(t * 0.5f + seg * 0.5f) * 5.0f * turnStrength
147: 					 + sin(sa + 1.0f) * 6.0f * swirlStrength) * ampMod,
148: 					(cos(t * 0.3f + seg * 0.3f) * 3.0f * twistStrength) * ampMod,
149: 					(sin(t * 0.4f + seg * 0.9f) * 3.5f
150: 					 + cos(sa + 1.0f) * 6.0f * swirlStrength) * ampMod);
151: 				path.push_back(path[n-1] + step + wobble);
152: 				freeSeg++;
153: 			}
154: 		}
155: 	}
