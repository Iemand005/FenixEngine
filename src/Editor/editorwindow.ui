              <property name="plainText">
               <string>#version 330 core
out vec4 FragColor;

in vec3 normal;
in vec2 TexCoord;

uniform sampler2D ourTexture;

void main()
{
    FragColor = texture(ourTexture, TexCoord) * vec4(vec3(1.0) * normal.x * 1 + 0.5, 1.0);
}</string>
