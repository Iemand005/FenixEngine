[submodule "third_party/glfw"]
	path = external/glfw
	url = https://github.com/glfw/glfw
[submodule "third_party/imgui"]
	path = external/imgui
	url = https://github.com/ocornut/imgui
[submodule "third_party/assimp"]
	path = third_party/assimp
	url = https://github.com/assimp/assimp
[submodule "third_party/OpenXR-SDK"]
	path = external/OpenXR-SDK
	url = https://github.com/KhronosGroup/OpenXR-SDK.git
[submodule "third_party/JoltPhysics"]
	path = external/JoltPhysics
	url = https://github.com/jrouwe/JoltPhysics.git
[submodule "external/SDL"]
	path = external/SDL
	url = https://github.com/libsdl-org/SDL
[submodule "external/glm"]
	path = external/glm
	url = https://github.com/g-truc/glm.git
