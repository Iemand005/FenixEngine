{
  "tasks": [
    {
      "label": "Copy resources",
      "type": "shell",
      "command": "copy",
      "args": [
        "config\\debug_config.json",
        "build\\debug_config.json"
      ],
      "windows": {
        "command": "copy"
      },
      "linux": {
        "command": "cp"
      }
    },
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-G",
        "MinGW Makefiles",
        "-B",
        "${workspaceFolder}/build",
        "-S",
        "${workspaceFolder}"
      ],
      "group": "build"
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build",
        "--config",
        "Debug",
        "-j8"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ],
  "version": "2.0.0"
}