{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: cl.exe build active file",
      "command": "cl.exe",
      "args": [
        "${workspaceFolder}/src/glad.c",
        "${workspaceFolder}/src/imgui/imgui.cpp",
        "${workspaceFolder}/src/imgui/imgui_draw.cpp",
        "${workspaceFolder}/src/imgui/imgui_tables.cpp",
        "${workspaceFolder}/src/imgui/imgui_widgets.cpp",
        "${workspaceFolder}/src/imgui/imgui_impl_glfw.cpp",
        "${workspaceFolder}/src/imgui/imgui_impl_opengl3.cpp",
        "${workspaceFolder}/src/main.cpp",
        "/Zi",
        "/EHsc",
        "/MDd",
        "/Fe${workspaceFolder}\\build\\main.exe",
        "/nologo",
        "/I${workspaceFolder}\\include",
        "/std:c++17",
        "gdi32.lib",
        "/link",
        "/LIBPATH:${workspaceFolder}\\lib",
        "glfw3.lib",
        "opengl32.lib",
        "shell32.lib",
        "opengl32.lib",
        "user32.lib",
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    }
  ],
  "version": "2.0.0"
}