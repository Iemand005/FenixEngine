        "${workspaceFolder}/src/engine.cpp",
        "${workspaceFolder}/src/main.cpp",
        "/Zi",
        "/EHsc",
        "/MDd",
        "/Fe${workspaceFolder}\\build\\main.exe",
        "/nologo",
        "/I${workspaceFolder}\\include",
        "/std:c++17",
        "/link",
        "/LIBPATH:${workspaceFolder}\\lib",
        "gdi32.lib", "glfw3.lib", "Opengl32.lib", "shell32.lib", "user32.lib",
      ],
      "options": {
        "cwd": "${fileDirname}"
