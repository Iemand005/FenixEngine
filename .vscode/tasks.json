      "command": "cl.exe",
      "args": [
        "${workspaceFolder}\\src\\*.c",
        "${workspaceFolder}\\src\\*.cpp",
        "/Zi",
        "/EHsc",
        "/FS",
        "/MDd",
        "/Fe${workspaceFolder}\\build\\debug\\main.exe",
        "/Foobj\\",
        "/nologo",
        "/I${workspaceFolder}\\include",
        "/I${workspaceFolder}\\third_party\\JoltPhysics",
        "/std:c++17",
        "/link",
        "/LIBPATH:${workspaceFolder}\\lib\\debug",
        "gdi32.lib", "glfw3.lib", "Opengl32.lib", "shell32.lib", "user32.lib", "Jolt.lib"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\cache"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    },
